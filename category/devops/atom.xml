;attr&#34;&gt;Cache:&lt;/span&gt; &lt;span class=&#34;string&#34;&gt;Redis&lt;/span&gt; &lt;span class=&#34;string&#34;&gt;(Deployment&lt;/span&gt; &lt;span class=&#34;string&#34;&gt;+&lt;/span&gt; &lt;span class=&#34;string&#34;&gt;Service)&lt;/span&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;  &lt;span class=&#34;bullet&#34;&gt;-&lt;/span&gt; &lt;span class=&#34;string&#34;&gt;日志:&lt;/span&gt; &lt;span class=&#34;string&#34;&gt;EFK&lt;/span&gt; &lt;span class=&#34;string&#34;&gt;/&lt;/span&gt; &lt;span class=&#34;string&#34;&gt;LPL&lt;/span&gt; &lt;span class=&#34;string&#34;&gt;(可选)&lt;/span&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;string&#34;&gt;管理方式:&lt;/span&gt; &lt;span class=&#34;string&#34;&gt;一个&lt;/span&gt; &lt;span class=&#34;string&#34;&gt;umbrella&lt;/span&gt; &lt;span class=&#34;string&#34;&gt;Chart&lt;/span&gt; &lt;span class=&#34;string&#34;&gt;包含以上所有子&lt;/span&gt; &lt;span class=&#34;string&#34;&gt;Chart&lt;/span&gt;&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/figure&gt;

